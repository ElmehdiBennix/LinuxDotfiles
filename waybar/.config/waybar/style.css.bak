

/* ============================================================================= */
/* --- Module-Specific Overrides & States --- */
/* ============================================================================= */

/* --- CPU (override base color) --- */
#cpu {
    color: @color14;
}


/* --- Audio --- */
#pulseaudio.sink-muted {
    color: #d79921;
    background-color: rgba(255, 255, 0, 0.1);
}

#custom-microphone.source-muted {
    color: #cc241d;
    background-color: rgba(255, 0, 0, 0.1);
}


/* --- Notifications --- */
#custom-notification.notification {
    color: #d79921;
}

#custom-notification.dnd-notification,
#custom-notification.inhibited-notification {
    color: #cc241d;
}


/* --- System Monitors (Modules inside the drawer) --- */
/* Individual colors for the drawer modules (size is handled by the unified style) */
#temperature {
    color: #81A1C1;
}

#memory {
    color: #A3BE8C;
}

#disk {
    color: #B48EAD;
}

/* Shared warning/critical states for drawer modules */
#temperature.warning,
#memory.warning,
#disk.warning {
    color: #EBCB8B;
    /* Warning Yellow */
    background-color: rgba(235, 203, 139, 0.15);
}

#temperature.critical,
#memory.critical,
#disk.critical {
    color: #BF616A;
    /* Critical Red */
    background-color: rgba(191, 97, 106, 0.2);
    font-weight: bold;
}
