# --- VIRTUAL DISPLAY SETUP ---
# This creates the virtual monitor that Sunshine will "see"
monitor=headless-0,1920x1080@60,0x0,1

# This forces the physical laptop screen to stay ignored
monitor=eDP-1,disable

# --- HEADLESS STABILITY SETTINGS ---
# Environment variables inside the config to ensure headless mode
env = AQ_PLATFORM,headless
env = WLR_BACKENDS,headless
env = WLR_LIBINPUT_NO_DEVICES,1
env = WLR_RENDERER,gles2

# NVIDIA fixes for headless
env = WLR_NO_HARDWARE_CURSORS,1
env = LIBVA_DRIVER_NAME,nvidia
env = __GLX_VENDOR_LIBRARY_NAME,nvidia

# --- PERFORMANCE / SERVER OPTIMIZATIONS ---
misc {
    disable_hyprland_logo = true
    disable_splash_rendering = true
    force_default_wallpaper = 0
}

# No animations = less GPU/CPU usage for the stream
animations {
    enabled = false
}

# --- AUTOSTART ---
# Start Sunshine inside this specific session
exec-once = sunshine
