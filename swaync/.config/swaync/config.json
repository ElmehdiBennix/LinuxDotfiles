{
    "$schema": "/etc/xdg/swaync/configSchema.json",
    "positionX": "center",
    "positionY": "top",
    "layer-shell": true,
    "layer": "overlay",
    "control-center-layer": "overlay",
    "control-center-positionX": "center",
    "control-center-positionY": "top",
    "control-center-height": 600,
    "control-center-width": 600,
    "control-center-margin-top": 12,
    "fit-to-screen": false,
    "keyboard-shortcuts": false,
    "cssPriority": "user",
    "notification-2fa-action": true,
    "notification-inline-replies": false,
    "notification-body-image-height": 100,
    "notification-body-image-width": 200,
    "timeout": 10,
    "timeout-low": 5,
    "timeout-critical": 0,
    "notification-window-width": 500,
    "notification-window-height": -1,
    "notification-grouping": false,
    "image-visibility": "when-available",
    "transition-time": 200,
    "hide-on-clear": true,
    "hide-on-action": true,
    "script-fail-notify": true,
    "relative-timestamps": true,
    "widgets": [
        "mpris",
        "notifications",
        "buttons-grid"
    ],
    "widget-config": {
        "mpris": {
            "autohide": true,
            "show-album-art": "never",
            "loop-carousel": true
        },
        "buttons-grid": {
            "actions": [
                {
                    "label": "󰒲  system state",
                    "command": "swaync-client -cp && ~/.config/vicinae/menus/power_mode.sh"
                },
                {
                    "label": "󰟎 Screen",
                    "command": "swaync-client -cp && hyprshot -m region -- ~/.config/vicinae/menus/screenshot_edit.sh"
                },
                {
                    "label": "󰈔 Color",
                    "command": "swaync-client -cp && ~/.config/vicinae/menus/hyprpicker_menu.sh"
                },
                {
                    "label": "󰛨 Flux",
                    "command": "swaync-client -cp; ~/.config/vicinae/menus/flux_toggle.sh",
                    "update-command": "pgrep -x hyprsunset > /dev/null && echo true || echo false"
                },
                {
                    "label": "󰏆 Wallpaper",
                    "command": "swaync-client -cp && ~/.config/vicinae/menus/wallpaper_picker.sh"
                },
                {
                    "label": "󰍹 Display",
                    "command": "swaync-client -cp && ~/.config/vicinae/menus/display_mode.sh"
                },
                {
                    "label": "󰐥 Power",
                    "command": "swaync-client -cp && wlogout"
                },
                {
                    "label": "󰆿 Clear",
                    "command": "swaync-client -C"
                }
            ]
        }
    }
}
